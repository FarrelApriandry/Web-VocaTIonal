# PHPStan configuration for VocaTIonal project
parameters:
    # Level of strictness (0-9, where 9 is most strict)
    level: 8
    
    # Paths to analyze
    paths:
        - app/
        - public/
    
    # Exclude paths
    excludePaths:
        - vendor/**
        - node_modules/**
    
    # Bootstrap file for autoloading
    bootstrapFiles:
        - vendor/autoload.php
    
    # Scan directories for classes
    scanDirectories:
        - app/
    
    # Scan files for classes
    scanFiles:
        - public/index.php
    
    # Error reporting
    reportUnmatchedIgnoredErrors: true
    
    # PHP version compatibility
    phpVersion: 80200
    
    # Custom rules
    checkMissingIterableValueType: true
    checkGenericClassInNonGenericObjectType: false
    
    # Ignore errors
    ignoreErrors:
        # Ignore errors related to dynamic properties
        - '#^Property [a-zA-Z\\_]+::\$[a-zA-Z\\_]+ \(dynamic property\) has no type specified\.$#'
        
        # Ignore errors related to undefined variables in global scope
        - '#^Undefined variable: \$[a-zA-Z_]+ in .*$#'
    
    # Include helper files
    includes:
        - vendor/phpstan/phpstan-phpunit/extension.neon
        - vendor/phpstan/phpstan-phpunit/rules.neon

# Services configuration
services:
    # Add custom services if needed
    -
        class: PHPStan\Rules\Deprecations\DeprecatedScopeRule
        tags:
            - phpstan.rules.rule