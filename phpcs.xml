<?xml version="1.0"?>
<ruleset name="VocaTIonal PHP Standards">
    <description>PHP CodeSniffer configuration for VocaTIonal project</description>
    
    <!-- Target directories -->
    <file>app/</file>
    <file>public/</file>
    
    <!-- Exclude directories -->
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>
    
    <!-- PHP version compatibility -->
    <config name="php_version" value="80200"/>
    
    <!-- Error reporting -->
    <arg name="colors"/>
    <arg name="tab-width" value="4"/>
    <arg value="sp"/>
    <arg name="extensions" value="php"/>
    
    <!-- Standards to use -->
    <rule ref="PSR12"/>
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="150"/>
        </properties>
    </rule>
    
    <!-- Custom rules -->
    <rule ref="Generic.PHP.DeprecatedFunctions"/>
    <rule ref="Generic.PHP.ForbiddenFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <element key="die" value="exit"/>
                <element key="mysql_connect" value="mysqli_connect or PDO"/>
                <element key="mysql_query" value="mysqli_query or PDO"/>
            </property>
        </properties>
    </rule>
    
    <!-- Security rules -->
    <rule ref="Security"/>
    
    <!-- Error severity -->
    <severity>1</severity>
</ruleset>